{
  "name": "playwright-atdd-example-webapp",
  "private": true,
  "version": "1.68.2",
  "type": "module",
  "scripts": {
    "start:dev": "vite",
    "build": "pnpm checks && pnpm build:vite",
    "checks": "pnpm typescript:checks && pnpm lint && pnpm test",
    "typescript:checks": "tsc --build",
    "lint": "eslint",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "build:vite": "vite build",
    "fix:lint": "eslint --fix",
    "fix:lineEndings": "pnpm exec prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html,yml,yaml,mts}\" --end-of-line lf",
    "start:build": "vite preview",
    "release": "semantic-release"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "clsx": "2.1.1",
    "eslint": "9.36.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.22",
    "eslint-plugin-security": "3.0.1",
    "globals": "16.4.0",
    "jsdom": "27.0.0",
    "prettier": "3.6.2",
    "react-router": "7.13.1",
    "tailwind-merge": "3.3.1",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.3",
    "typescript-eslint": "8.45.0",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
